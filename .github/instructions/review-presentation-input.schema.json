{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wodansson.github.io/terraform-azurerm-ai-assisted-development/.github/instructions/review-presentation-input.schema.json",
  "title": "Review Presentation Payload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "reviewMode",
    "changeDescription",
    "changeSummaryLines",
    "primaryChangesAnalysis",
    "recursionPreventionLines",
    "standardsCheckLines",
    "linterReport",
    "mustFix",
    "strengths",
    "observations",
    "issues",
    "immediateRecommendations",
    "futureConsiderations",
    "overallAssessment",
    "verificationFooter"
  ],
  "properties": {
    "reviewMode": {
      "type": "string",
      "enum": [
        "local",
        "committed"
      ]
    },
    "changeDescription": {
      "type": "string",
      "minLength": 1,
      "description": "A concise change-focused review title for the final review heading, not merely a generic scope label when richer evidence exists."
    },
    "changeSummaryLines": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "modifiedFiles": {
      "$ref": "#/$defs/stringArray"
    },
    "addedFiles": {
      "$ref": "#/$defs/stringArray"
    },
    "untrackedFiles": {
      "$ref": "#/$defs/stringArray"
    },
    "deletedFiles": {
      "$ref": "#/$defs/stringArray"
    },
    "skippedVendoredFiles": {
      "type": "integer",
      "minimum": 0
    },
    "primaryChangesAnalysis": {
      "type": "string",
      "minLength": 1
    },
    "recursionPreventionLines": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "standardsCheckLines": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "linterReport": {
      "$ref": "#/$defs/linterReport"
    },
    "mustFix": {
      "$ref": "#/$defs/stringArray"
    },
    "strengths": {
      "$ref": "#/$defs/findingArray"
    },
    "observations": {
      "$ref": "#/$defs/structuredFindingArrayOrExplicitNone"
    },
    "issues": {
      "$ref": "#/$defs/structuredFindingArrayOrExplicitNone"
    },
    "immediateRecommendations": {
      "$ref": "#/$defs/nonEmptyStringArrayOrExplicitNone"
    },
    "futureConsiderations": {
      "$ref": "#/$defs/nonEmptyStringArrayOrExplicitNone"
    },
    "overallAssessment": {
      "type": "string",
      "minLength": 1
    },
    "verificationFooter": {
      "$ref": "#/$defs/verificationFooter"
    }
  },
  "$defs": {
    "linterReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "status",
        "runScope",
        "issueCount",
        "summary"
      ],
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "runScope": {
          "type": "string",
          "minLength": 1
        },
        "issueCount": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": false
    },
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": false
    },
    "nonEmptyStringArrayOrExplicitNone": {
      "oneOf": [
        {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        {
          "$ref": "#/$defs/explicitNoneArray"
        }
      ]
    },
    "verificationFooter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preflightComplete",
        "skillsUsed",
        "requiredStages",
        "executedStages"
      ],
      "properties": {
        "preflightComplete": {
          "type": "boolean",
          "const": true
        },
        "skillsUsed": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "requiredStages": {
          "$ref": "#/$defs/routedStageArray"
        },
        "executedStages": {
          "$ref": "#/$defs/routedStageArray"
        }
      }
    },
    "routedStageName": {
      "type": "string",
      "enum": [
        "review-coordinator",
        "review-reviewer",
        "review-architect",
        "review-skeptic",
        "review-advocate",
        "review-moderator",
        "review-presentation"
      ]
    },
    "routedStageArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/routedStageName"
      },
      "uniqueItems": true
    },
    "findingArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/findingItem"
      },
      "uniqueItems": false
    },
    "structuredFindingArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/structuredFinding"
      },
      "uniqueItems": false
    },
    "explicitNoneArray": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "type": "string",
        "const": "- None"
      }
    },
    "structuredFindingArrayOrExplicitNone": {
      "oneOf": [
        {
          "$ref": "#/$defs/structuredFindingArray"
        },
        {
          "$ref": "#/$defs/explicitNoneArray"
        }
      ]
    },
    "findingItem": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "$ref": "#/$defs/structuredFinding"
        }
      ]
    },
    "structuredFinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reviewType",
        "summary",
        "priority",
        "file",
        "evidence",
        "impact"
      ],
      "properties": {
        "reviewType": {
          "type": "string",
          "enum": [
            "change-request",
            "nitpick",
            "refactor-suggestion",
            "thought-or-concern",
            "positive-feedback",
            "future-consideration"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "priority": {
          "type": "string",
          "enum": [
            "critical",
            "high",
            "medium",
            "low",
            "observation",
            "notable",
            "good"
          ]
        },
        "file": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "string",
          "minLength": 1
        },
        "impact": {
          "type": "string",
          "minLength": 1
        },
        "suggestedChange": {
          "type": "string",
          "minLength": 1
        },
        "currentCode": {
          "type": "string",
          "minLength": 1
        },
        "correctedCode": {
          "type": "string",
          "minLength": 1
        },
        "codeLanguage": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
